{
  "name": "@mem9/mem9",
  "version": "0.4.11",
  "description": "OpenClaw shared memory plugin — cloud-persistent memory with hybrid vector + keyword search via mnemo-server",
  "type": "module",
  "license": "Apache-2.0",
  "author": "mem9-ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mem9-ai/mem9.git",
    "directory": "openclaw-plugin"
  },
  "homepage": "https://github.com/mem9-ai/mem9/tree/main/openclaw-plugin#readme",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "memory",
    "agent-memory",
    "tidb",
    "vector-search",
    "persistent-memory",
    "ai-agent"
  ],
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf ./dist && tsc -p ./tsconfig.build.json",
    "prepack": "npm run build",
    "test": "rm -rf ./dist-test && tsc -p ./tsconfig.test.json && node --test ./dist-test/*.test.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "peerDependencies": {
    "openclaw": ">=2026.1.26"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.15.30",
    "typescript": "^5.5.0"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ]
  }
}
