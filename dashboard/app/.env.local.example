# Local development defaults.
# Copy this file to .env.local for local work.

# Set to "true" for full mock mode (no real API needed).
# Set to "false" to use real API for CRUD, with mock fallback for
# features not yet backed by real API (topic summary, facet data).
VITE_USE_MOCK=true
# Set to "true" to use mock session preview data for insight memories while
# keeping the main list on the current provider. Keep this off in shared .env;
# enable it locally when you want the session-preview demo behavior.
VITE_ENABLE_MOCK_SESSION_PREVIEW=true
VITE_API_BASE=/your-memory/api
VITE_ANALYSIS_API_BASE=/your-memory/analysis-api
# Optional: override the Vite dev proxy target without changing frontend paths.
VITE_API_PROXY_TARGET=https://api.mem9.ai
VITE_ANALYSIS_PROXY_TARGET=https://napi.mem9.ai
VITE_GA4_MEASUREMENT_ID=
VITE_MIXPANEL_TOKEN=

# Feature flags — control which UI sections are visible.
VITE_ENABLE_MANUAL_ADD=true
VITE_ENABLE_TIME_RANGE=true
VITE_ENABLE_FACET=true
VITE_ENABLE_TOPIC_SUMMARY=true
VITE_ENABLE_ANALYSIS=false
VITE_ANALYSIS_BATCH_SIZE=100
VITE_ANALYSIS_POLL_MS=1500
