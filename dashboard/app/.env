# Shared default for preview and real-API smoke checks.
# For local UI-first work, copy .env.local.example to .env.local instead.
VITE_USE_MOCK=false
VITE_API_BASE=/your-memory/api

# Planned feature flags for UI-first work.
# They may be ignored until src/config/features.ts lands.
VITE_ENABLE_MANUAL_ADD=true
VITE_ENABLE_TIME_RANGE=true
VITE_ENABLE_FACET=true
VITE_ENABLE_TOPIC_SUMMARY=true
