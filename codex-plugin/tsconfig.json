{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "noEmit": true,
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": [
    "skills/**/*.mjs",
    "runtime/**/*.mjs",
    "tests/**/*.mjs"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
