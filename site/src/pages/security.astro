---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { DEFAULT_LOCALE, siteCopy } from '../content/site';

const copy = siteCopy[DEFAULT_LOCALE];
const page = copy.securityPage;
---

<Layout
  meta={page.meta}
  locale={DEFAULT_LOCALE}
  metaTitleKey="securityPage.meta.title"
  metaDescriptionKey="securityPage.meta.description"
>
  <Navbar
    nav={copy.nav}
    aria={copy.aria}
    localeNames={copy.localeNames}
    themeOptions={copy.themeOptions}
  />

  <main class="security-page">
    <section class="security-hero">
      <div class="container">
        <div class="security-hero-copy">
          <p class="section-kicker" data-i18n="securityPage.kicker">{page.kicker}</p>
          <h1 class="section-title page-title" data-i18n="securityPage.title">{page.title}</h1>
          <p class="section-desc page-desc" data-i18n="securityPage.intro">
            {page.intro}
          </p>
        </div>
      </div>
    </section>

    <section class="security-content">
      <div class="container security-stack">
        <article class="security-panel surface-card">
          <h2 class="panel-title" data-i18n="securityPage.dataTitle">{page.dataTitle}</h2>
          <p class="panel-body" data-i18n="securityPage.dataBody">
            {page.dataBody}
          </p>
        </article>

        <div class="security-section-head">
          <h2 class="panel-title" data-i18n="securityPage.protectionsTitle">
            {page.protectionsTitle}
          </h2>
        </div>

        <div class="protection-grid">
          {page.protections.map((item, index) => (
            <article class="protection-card surface-card">
              <h3 class="protection-title" data-i18n={`securityPage.protections.${index}.title`}>
                {item.title}
              </h3>
              <p
                class="protection-body"
                data-i18n={`securityPage.protections.${index}.description`}
              >
                {item.description}
              </p>
            </article>
          ))}
        </div>

        <article class="security-panel surface-card">
          <h2 class="panel-title" data-i18n="securityPage.trustTitle">{page.trustTitle}</h2>
          <p class="panel-body" data-i18n="securityPage.trustBody">
            {page.trustBody}
          </p>
        </article>
      </div>
    </section>
  </main>

  <Footer footer={copy.footer} />
</Layout>

<style>
  .security-page {
    padding-bottom: 1rem;
  }

  .security-hero {
    padding-top: clamp(3.5rem, 7vw, 6rem);
    padding-bottom: 2.2rem;
  }

  .security-hero-copy {
    width: min(100%, var(--content-rail));
  }

  .page-title {
    max-width: 12ch;
  }

  .page-desc {
    max-width: 62ch;
  }

  .security-content {
    padding-top: 0;
    padding-bottom: 4.5rem;
  }

  .security-stack {
    display: grid;
    gap: 1.25rem;
  }

  .security-panel {
    width: min(100%, var(--section-grid));
    margin: 0 auto;
    padding: 1.5rem;
    background: linear-gradient(180deg, var(--surface-elevated-start), var(--surface-elevated-end));
  }

  .security-section-head {
    width: min(100%, var(--section-grid));
    margin: 0 auto;
  }

  .panel-title {
    font-size: 1.2rem;
    margin-bottom: 0.65rem;
    letter-spacing: -0.03em;
  }

  .panel-body {
    color: var(--text-dim);
    font-size: 1rem;
    line-height: 1.68;
  }

  .protection-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
    width: min(100%, var(--section-grid));
    margin: 0 auto;
  }

  .protection-card {
    padding: 1.35rem;
    background: linear-gradient(180deg, var(--surface-gradient-start), var(--surface-gradient-end));
  }

  .protection-title {
    font-size: 1.05rem;
    margin-bottom: 0.55rem;
    letter-spacing: -0.03em;
  }

  .protection-body {
    color: var(--text-dim);
    font-size: 0.96rem;
    line-height: 1.58;
  }

  @media (max-width: 720px) {
    .protection-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
