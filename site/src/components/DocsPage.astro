---
import { docsCopy, resolveDocsLocale, type DocsLink, type DocsLocale } from '../content/docs';
import { DEFAULT_LOCALE } from '../content/site';

const localeOrder: DocsLocale[] = ['zh', 'en', 'ja', 'ko', 'id', 'th'];
const initialDocsLocale = resolveDocsLocale(DEFAULT_LOCALE);

function linkTarget(link: DocsLink): string | undefined {
  return link.external ? '_blank' : undefined;
}

function linkRel(link: DocsLink): string | undefined {
  return link.external ? 'noopener noreferrer' : undefined;
}
---

<section class="docs-page" data-docs-root data-docs-locale="zh">
  <div class="docs-progress-bar" data-docs-progress></div>
  {localeOrder.map((locale) => {
    const copy = docsCopy[locale];
    const sectionMap = new Map(copy.sections.map((section) => [section.id, section]));
    return (
      <div
        class="docs-copy"
        data-docs-copy={locale}
        hidden={locale !== initialDocsLocale}
      >
        <div class="container docs-shell">
          <div class="docs-layout">
            <aside class="docs-sidebar">
              <button class="docs-toc-toggle" data-docs-toc-toggle type="button">
                <span>{copy.hero.tocTitle}</span>
                <span class="docs-toc-toggle-icon" aria-hidden="true"></span>
              </button>
              <div class="docs-toc surface-card">
                <p class="docs-toc-title">{copy.hero.tocTitle}</p>
                <nav aria-label={copy.hero.tocTitle}>
                  <div class="docs-toc-groups">
                    {copy.tocGroups.map((group) => (
                      <details class="docs-toc-group" open>
                        <summary class="docs-toc-group-summary">
                          <span class="docs-toc-group-title">{group.title}</span>
                          <span class="docs-toc-group-icon" aria-hidden="true"></span>
                        </summary>
                        <ol class="docs-toc-list">
                          {group.sectionIDs.map((sectionID) => {
                            const section = sectionMap.get(sectionID);
                            if (!section) return null;

                            return (
                              <li>
                                <a href={`#${section.id}`} class="docs-toc-link">
                                  <span class="docs-toc-index">{section.label}</span>
                                  <span>{section.title}</span>
                                </a>
                              </li>
                            );
                          })}
                        </ol>
                      </details>
                    ))}
                  </div>
                </nav>
              </div>
            </aside>

            <div class="docs-content">
              {copy.sections.map((section) => (
                <article
                  class="docs-section"
                  id={locale === initialDocsLocale ? section.id : undefined}
                  data-docs-anchor={section.id}
                >
                  <div class="docs-section-head">
                    <p class="docs-section-label">{section.label}</p>
                    <h2 class="docs-section-title">{section.title}</h2>
                    {section.intro && <p class="docs-section-intro">{section.intro}</p>}
                  </div>

                  {section.paragraphs?.map((paragraph) => (
                    <p class="docs-paragraph" set:html={paragraph}></p>
                  ))}

                  {section.bullets && (
                    <ul class="docs-bullets">
                      {section.bullets.map((bullet) => (
                        <li>{bullet}</li>
                      ))}
                    </ul>
                  )}

                  {section.subsections?.map((subsection) => (
                    <section class="docs-subsection surface-card">
                      <h3 class="docs-subsection-title">{subsection.title}</h3>
                      {subsection.paragraphs?.map((paragraph) => (
                        <p class="docs-paragraph" set:html={paragraph}></p>
                      ))}
                      {subsection.bullets && (
                        <ul class="docs-bullets is-compact">
                          {subsection.bullets.map((bullet) => (
                            <li>{bullet}</li>
                          ))}
                        </ul>
                      )}
                      {subsection.links && subsection.links.length > 0 && (
                        <div class="docs-link-row">
                          {subsection.links.map((link) => (
                            <a
                              href={link.href}
                              target={linkTarget(link)}
                              rel={linkRel(link)}
                              class="docs-inline-link"
                            >
                              {link.label}
                              {link.external && (
                                <svg class="docs-external-icon" viewBox="0 0 16 16" aria-hidden="true">
                                  <path d="M6.5 3.5h-3a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1v-3" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                  <path d="M9.5 2.5h4v4M13.5 2.5l-6 6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                              )}
                            </a>
                          ))}
                        </div>
                      )}
                    </section>
                  ))}

                  {section.links && section.links.length > 0 && (
                    <div class="docs-link-row">
                      {section.links.map((link) => (
                        <a
                          href={link.href}
                          target={linkTarget(link)}
                          rel={linkRel(link)}
                          class="docs-inline-link"
                        >
                          {link.label}
                          {link.external && (
                            <svg class="docs-external-icon" viewBox="0 0 16 16" aria-hidden="true">
                              <path d="M6.5 3.5h-3a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1v-3" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                              <path d="M9.5 2.5h4v4M13.5 2.5l-6 6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                          )}
                        </a>
                      ))}
                    </div>
                  )}
                </article>
              ))}
            </div>
          </div>
        </div>
      </div>
    );
  })}

  <button class="docs-back-to-top" data-docs-back-to-top hidden type="button" aria-label="Back to top">
    <svg viewBox="0 0 16 16" aria-hidden="true">
      <path d="M8 12.5V3.5M4 7l4-4 4 4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
</section>

<style>
  .docs-page {
    padding: 1.2rem 0 4.8rem;
  }

  .docs-page .docs-copy[hidden] {
    display: none;
  }

  .docs-shell {
    display: grid;
    gap: 0;
  }

  .docs-layout {
    display: grid;
    grid-template-columns: minmax(14rem, 17rem) minmax(0, 1fr);
    gap: 1.35rem;
    align-items: start;
  }

  .docs-sidebar {
    position: sticky;
    top: 5.7rem;
    max-height: calc(100dvh - 6.5rem);
    min-height: 0;
  }

  .docs-toc {
    padding: 0.95rem;
    max-height: inherit;
    overflow-y: auto;
    overscroll-behavior: contain;
    scrollbar-gutter: stable;
    -webkit-overflow-scrolling: touch;
  }

  .docs-toc::-webkit-scrollbar {
    width: 0.55rem;
  }

  .docs-toc::-webkit-scrollbar-thumb {
    background: var(--button-active-border);
    border-radius: 999px;
  }

  .docs-toc::-webkit-scrollbar-track {
    background: transparent;
  }

  .docs-toc-title {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.9rem;
  }

  .docs-toc-list {
    list-style: none;
    display: grid;
    gap: 0.3rem;
  }

  .docs-toc-groups {
    display: grid;
    gap: 0.5rem;
  }

  .docs-toc-group {
    display: grid;
    gap: 0.2rem;
    border-top: 1px solid var(--border);
    padding-top: 0.5rem;
  }

  .docs-toc-group:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .docs-toc-group-summary {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    cursor: pointer;
    padding: 0.3rem 0.45rem;
    border-radius: 0.65rem;
  }

  .docs-toc-group-summary::-webkit-details-marker {
    display: none;
  }

  .docs-toc-group-summary:hover {
    background: var(--button-active-bg);
  }

  .docs-toc-group-title {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-soft);
  }

  .docs-toc-group-icon {
    width: 0.56rem;
    height: 0.56rem;
    border-right: 1.5px solid var(--text-soft);
    border-bottom: 1.5px solid var(--text-soft);
    transform: rotate(45deg) translateY(-1px);
    transition: transform 0.2s ease;
    flex: 0 0 auto;
  }

  .docs-toc-group:not([open]) .docs-toc-group-icon {
    transform: rotate(-45deg) translateY(1px);
  }

  .docs-toc-link {
    display: grid;
    grid-template-columns: 2rem minmax(0, 1fr);
    gap: 0.6rem;
    padding: 0.42rem 0.45rem 0.42rem 0.6rem;
    border-radius: 0.8rem;
    border-left: 2px solid transparent;
    color: var(--text-dim);
    line-height: 1.35;
    transition: background-color 0.2s, color 0.2s, border-color 0.2s;
  }

  .docs-toc-link:hover {
    background: var(--button-active-bg);
    color: var(--text);
    opacity: 1;
  }

  .docs-toc-link.is-active {
    background: var(--button-active-bg);
    color: var(--text);
    border-left-color: var(--accent);
    opacity: 1;
  }

  .docs-toc-index {
    font-family: var(--font-mono);
    color: var(--accent);
    font-size: 0.92em;
  }

  .docs-content {
    display: grid;
    gap: 1.2rem;
  }

  .docs-section {
    padding: 1.3rem 1.3rem 1.4rem;
    border: 1px solid var(--border);
    border-radius: 1.15rem;
    background: linear-gradient(180deg, var(--surface-gradient-start), var(--surface-gradient-end));
    box-shadow: var(--surface-inset), var(--surface-shadow);
    scroll-margin-top: 6rem;
  }

  .docs-section-head {
    margin-bottom: 0.95rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.95rem;
  }

  .docs-section-label {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.65rem;
    display: inline-block;
    background: var(--accent-soft);
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
  }

  .docs-section-title {
    font-size: clamp(1.45rem, 2.2vw, 2rem);
    margin-bottom: 0.45rem;
  }

  .docs-section-intro {
    color: var(--text-dim);
    line-height: 1.7;
  }

  .docs-paragraph {
    color: var(--text-dim);
    line-height: 1.8;
    margin-top: 0.9rem;
  }

  .docs-paragraph :global(a) {
    color: var(--text);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--text) 50%, transparent);
    text-underline-offset: 0.16em;
  }

  .docs-paragraph :global(a:hover) {
    opacity: 1;
    color: var(--accent);
    text-decoration-color: currentColor;
  }

  .docs-bullets {
    margin-top: 1rem;
    padding-left: 1.15rem;
    display: grid;
    gap: 0.6rem;
    color: var(--text-dim);
  }

  .docs-bullets li::marker {
    color: var(--accent);
  }

  .docs-bullets.is-compact {
    margin-top: 0.75rem;
    gap: 0.45rem;
  }

  .docs-subsection {
    padding: 1rem;
    margin-top: 1rem;
    border-left: 2px solid var(--accent);
  }

  .docs-subsection-title {
    font-size: 1.08rem;
  }

  .docs-link-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 1rem;
  }

  .docs-inline-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.52rem 0.75rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--button-bg);
    color: var(--text);
    font-size: 0.92rem;
    transition: border-color 0.2s, transform 0.2s;
  }

  .docs-inline-link:hover {
    border-color: var(--border-strong);
    transform: translateY(-1px);
    opacity: 1;
  }

  .docs-external-icon {
    width: 0.85em;
    height: 0.85em;
    opacity: 0.5;
    flex-shrink: 0;
  }

  /* Progress bar */
  .docs-progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    height: 2px;
    background: var(--accent);
    z-index: 25;
    width: 0%;
    pointer-events: none;
  }

  /* Back to top */
  .docs-back-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--button-bg);
    backdrop-filter: blur(8px);
    color: var(--text);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(0.5rem);
    transition: opacity 0.25s, transform 0.25s, border-color 0.2s, background-color 0.2s;
    z-index: 15;
    box-shadow: var(--surface-shadow-soft);
  }

  .docs-back-to-top[hidden] {
    display: none;
  }

  .docs-back-to-top.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .docs-back-to-top:hover {
    border-color: var(--border-strong);
    background: var(--button-hover-bg);
  }

  .docs-back-to-top svg {
    width: 1.1rem;
    height: 1.1rem;
  }

  /* Mobile TOC toggle */
  .docs-toc-toggle {
    display: none;
  }

  @media (max-width: 980px) {
    .docs-layout {
      grid-template-columns: 1fr;
    }

    .docs-sidebar {
      position: static;
      max-height: none;
    }

    .docs-toc-toggle {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      padding: 0.75rem 1rem;
      border: 1px solid var(--border);
      border-radius: 1rem;
      background: linear-gradient(180deg, var(--surface-gradient-start), var(--surface-gradient-end));
      box-shadow: var(--surface-inset), var(--surface-shadow-soft);
      color: var(--text);
      font-family: var(--font-mono);
      font-size: 0.8rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      cursor: pointer;
      transition: border-color 0.2s;
    }

    .docs-toc-toggle:hover {
      border-color: var(--border-strong);
    }

    .docs-toc-toggle-icon {
      width: 0.56rem;
      height: 0.56rem;
      border-right: 1.5px solid var(--text-soft);
      border-bottom: 1.5px solid var(--text-soft);
      transform: rotate(45deg) translateY(-1px);
      transition: transform 0.25s ease;
      flex-shrink: 0;
    }

    .docs-sidebar.is-toc-open .docs-toc-toggle-icon {
      transform: rotate(-135deg) translateY(-1px);
    }

    .docs-toc {
      max-height: 0;
      overflow: hidden;
      padding: 0 0.95rem;
      margin-top: 0.5rem;
      transition: max-height 0.3s ease, padding 0.3s ease;
    }

    .docs-sidebar.is-toc-open .docs-toc {
      max-height: 80vh;
      overflow-y: auto;
      padding: 0.95rem;
    }
  }

  @media (max-width: 720px) {
    .docs-page {
      padding: 0.75rem 0 3.8rem;
    }

    .docs-shell {
      gap: 0;
    }

    .docs-toc-link {
      grid-template-columns: 1.85rem minmax(0, 1fr);
      padding: 0.42rem 0.4rem 0.42rem 0.56rem;
    }

    .docs-section {
      padding: 1rem;
    }

    .docs-back-to-top {
      bottom: 1.2rem;
      right: 1.2rem;
    }
  }
</style>
