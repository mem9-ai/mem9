---
import { agentGuideTargets } from '../content/site';
import type { SitePlatformsCopy } from '../content/site';

interface Props {
  platforms: SitePlatformsCopy;
}

const { platforms } = Astro.props;
const hasSingleItem = platforms.items.length === 1;
const yourMemoryHref = '/your-memory/';
---

<section id="platforms" class="agents">
  <div class="container">
    <div class="section-head">
      <p class="section-kicker" data-i18n="platforms.kicker">{platforms.kicker}</p>
      <h2 class="section-title" data-i18n="platforms.title">{platforms.title}</h2>
      <p class="section-desc" data-i18n="platforms.description">
        {platforms.description}
      </p>
    </div>
    <div class="agent-grid">
      {platforms.items.map((agent, index) => {
        const guideTarget = agent.guideId ? agentGuideTargets[agent.guideId] : null;
        const href = guideTarget?.href ?? agent.href;
        const external = guideTarget?.external ?? agent.external ?? false;

        return (
          <div class:list={['agent-card', hasSingleItem && 'is-wide', agent.badge && 'has-action']}>
            <div class="agent-head">
              <div class="agent-name" data-i18n={`platforms.items.${index}.name`}>{agent.name}</div>
              {agent.badge && <span class="agent-badge">{agent.badge}</span>}
            </div>
            <div class="agent-desc" data-i18n={`platforms.items.${index}.desc`}>{agent.desc}</div>
            <div class="agent-detail" data-i18n={`platforms.items.${index}.detail`}>
              {agent.detail}
            </div>
            {href && !agent.badge && (
              <div class="agent-guide-row">
                <a
                  href={href}
                  target={external ? "_blank" : undefined}
                  rel={external ? "noopener noreferrer" : undefined}
                  class="agent-guide-link"
                >
                  <span data-i18n="platforms.guideCtaLabel">{platforms.guideCtaLabel}</span>
                  {external ? (
                    <span class="agent-cta-arrow" aria-hidden="true">↗</span>
                  ) : (
                    <span class="agent-cta-arrow" aria-hidden="true">→</span>
                  )}
                </a>
              </div>
            )}
            {agent.badge && (
              <div class="agent-action-row">
                <a
                  href={yourMemoryHref}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="agent-cta-button"
                >
                  <span data-i18n="platforms.ctaLabel">{platforms.ctaLabel}</span>
                  <span class="agent-cta-arrow" aria-hidden="true">↗</span>
                </a>
              </div>
            )}
          </div>
        );
      })}
    </div>
    <p class="agent-note" data-i18n="platforms.note">
      {platforms.note}
    </p>
  </div>
</section>

<style>
  .agents {
    padding: 4rem 0;
  }

  .section-title {
    max-width: 100%;
    text-wrap: balance;
  }

  .section-head {
    width: min(100%, var(--content-rail));
    margin: 0 auto 2rem;
  }

  .agent-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
    width: min(100%, var(--section-grid));
    margin: 0 auto;
  }

  .agent-card.is-wide {
    grid-column: 1 / -1;
  }

  .agent-card {
    display: flex;
    flex-direction: column;
    background: linear-gradient(180deg, var(--surface-gradient-start), var(--surface-gradient-end));
    border: 1px solid var(--border);
    border-radius: 1rem;
    padding: 1.5rem;
    box-shadow: var(--surface-inset), var(--surface-shadow);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .agent-card:hover {
    border-color: var(--border-strong);
    transform: translateY(-2px);
  }

  .agent-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.45rem;
  }

  .agent-name {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text);
  }

  .agent-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.48rem;
    border-radius: 999px;
    border: 1px solid var(--button-active-border);
    background: var(--button-active-bg);
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    line-height: 1;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .agent-desc {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--accent);
    margin-bottom: 0.75rem;
    letter-spacing: 0.05em;
  }

  .agent-detail {
    flex: 1 1 auto;
    font-size: 0.98rem;
    color: var(--text-dim);
    line-height: 1.4;
  }

  .agent-guide-row {
    margin-top: 1.15rem;
  }

  .agent-guide-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .agent-guide-link:hover,
  .agent-guide-link:focus-visible {
    color: var(--text);
  }

  .agent-action-row {
    margin-top: 1.15rem;
  }

  .agent-cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 0.95rem;
    border-radius: 0.65rem;
    border: 1px solid var(--button-active-border);
    background: var(--button-active-bg);
    color: var(--text);
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    text-decoration: none;
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .agent-cta-button:hover,
  .agent-cta-button:focus-visible {
    background: var(--button-hover-bg, var(--button-active-bg));
    border-color: var(--text);
    color: var(--text);
  }

  .agent-cta-arrow {
    font-size: 0.95rem;
    line-height: 1;
    opacity: 0.7;
  }

  .agent-guide-link .agent-cta-arrow {
    font-size: 0.85rem;
  }

  .agent-note {
    color: var(--text-dim);
    font-size: 0.95rem;
    margin-top: 1.5rem;
    width: min(100%, var(--content-rail));
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 640px) {
    .agent-grid {
      grid-template-columns: 1fr;
    }

    .agent-card.is-wide {
      grid-column: auto;
    }
  }
</style>
