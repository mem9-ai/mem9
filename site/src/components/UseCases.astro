---
import type { DiscoverabilityUseCasesCopy } from "../content/discoverability";

interface Props {
  useCases: DiscoverabilityUseCasesCopy;
}

const { useCases } = Astro.props;
---

<section id="use-cases" class="use-cases">
  <div class="container">
    <div class="section-head">
      <p class="section-kicker" data-i18n="useCases.kicker">{useCases.kicker}</p>
      <h2 class="section-title use-cases-title" data-i18n="useCases.title">
        {useCases.title}
      </h2>
      <p class="section-desc" data-i18n="useCases.description">
        {useCases.description}
      </p>
    </div>

    <div class="use-case-grid">
      {useCases.items.map((item, index) => (
        <article class="use-case-card surface-card">
          <h3 class="use-case-name" data-i18n={`useCases.items.${index}.title`}>
            {item.title}
          </h3>
          <p class="use-case-description" data-i18n={`useCases.items.${index}.description`}>
            {item.description}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .use-cases {
    padding: 4rem 0;
  }

  .use-cases-title {
    max-width: 13ch;
  }

  .section-head {
    width: min(100%, var(--content-rail));
    margin: 0 auto 2rem;
  }

  .use-case-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
    width: min(100%, var(--section-grid));
    margin: 0 auto;
  }

  .use-case-card {
    padding: 1.5rem;
  }

  .use-case-name {
    font-size: 1.12rem;
    margin-bottom: 0.7rem;
  }

  .use-case-description {
    color: var(--text-dim);
    line-height: 1.65;
  }

  @media (max-width: 640px) {
    .use-case-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
