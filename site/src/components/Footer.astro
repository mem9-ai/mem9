---
import type { SiteFooterCopy } from '../content/site';

interface Props {
  footer: SiteFooterCopy;
}

const { footer } = Astro.props;
const tidbCloudHref = 'https://www.pingcap.com?utm_source=mem9&utm_medium=referral&utm_campaign=agent-state-stack';
---

<footer class="footer">
  <div class="container footer-inner">
    <p class="brand"><span>MEM</span><span class="brand-accent">9</span></p>
    <div class="footer-links">
      <a href="https://github.com/mem9-ai/mem9" target="_blank" rel="noopener" data-i18n="footer.github">
        {footer.github}
      </a>
      <span class="sep">/</span>
      <a
        href="https://github.com/mem9-ai/mem9/blob/main/LICENSE"
        target="_blank"
        rel="noopener"
        data-i18n="footer.license"
      >
        {footer.license}
      </a>
      <span class="sep">/</span>
      <a
        href="https://github.com/mem9-ai/mem9/blob/main/CONTRIBUTING.md"
        target="_blank"
        rel="noopener"
        data-i18n="footer.contributing"
      >
        {footer.contributing}
      </a>
      <span class="sep">/</span>
      <a href="/#security" data-i18n="footer.security">
        {footer.security}
      </a>
      <span class="sep">/</span>
      <a
        href="mailto:mem9@pingcap.com"
        class="footer-contact-link"
        data-contact-modal-trigger
        data-i18n="footer.contact"
      >
        {footer.contact}
      </a>
    </div>
    <a
      href={tidbCloudHref}
      target="_blank"
      rel="noopener noreferrer"
      class="footer-credit"
    >
      <span data-i18n="footer.poweredByLabel">{footer.poweredByLabel}</span>
      <img src="/tidb-logo.svg" alt="TiDB Cloud" />
    </a>
    <p class="copyright" data-i18n="footer.copyright">
      {footer.copyright}
    </p>
  </div>
</footer>

<style>
  .footer {
    padding: 4rem 0 2.5rem;
    border-top: 1px solid var(--border);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .brand {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--text);
  }

  .brand-accent {
    color: var(--accent);
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--text-dim);
  }

  .sep {
    color: var(--text-dim);
  }

  .footer-contact-link {
    color: inherit;
  }

  .footer-credit {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.28rem 0.62rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--surface-elevated-end);
    color: var(--text-soft);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    letter-spacing: 0.02em;
    line-height: 1;
    text-decoration: none;
    transition: color 0.18s ease, border-color 0.18s ease;
  }

  .footer-credit:hover,
  .footer-credit:focus-visible {
    color: var(--text);
    border-color: var(--border-strong);
    opacity: 1;
  }

  .footer-credit img {
    display: block;
    width: auto;
    height: 0.82rem;
    transition: opacity 0.18s ease;
  }

  .footer-credit:hover img,
  .footer-credit:focus-visible img {
    opacity: 0.92;
  }

  .copyright {
    font-size: 0.85rem;
    color: var(--text-dim);
    text-align: center;
  }
</style>
