---
import { agentGuideTargets } from '../content/site';
import type { SiteAriaCopy, SiteHeroCopy } from '../content/site';

interface Props {
  hero: SiteHeroCopy;
  aria: SiteAriaCopy;
}

const { hero, aria } = Astro.props;
const showOnboardingVersionTabs = false;
const onboardingCommandUrlPattern = /https:\/\/\S+/u;
const poweredByLabel = hero.poweredByLabel ?? 'Powered by TiDB Cloud';
const substrateCtaLabel =
  hero.substrateCtaLabel
  ?? 'Need the backend substrate behind memory? Explore via TiDB Cloud Zero →';
const tidbCloudHref = 'https://www.pingcap.com?utm_source=mem9&utm_medium=referral&utm_campaign=agent-state-stack';
const tidbZeroHref = 'https://zero.tidbcloud.com?utm_source=mem9&utm_medium=referral&utm_campaign=agent-state-stack';

function splitOnboardingCommand(command: string): {
  prefix: string;
  url: string | null;
  suffix: string;
} {
  const match = command.match(onboardingCommandUrlPattern);

  if (!match || match.index === undefined) {
    return {
      prefix: command,
      url: null,
      suffix: '',
    };
  }

  const url = match[0];
  const prefix = command.slice(0, match.index);
  const suffix = command.slice(match.index + url.length);

  return { prefix, url, suffix };
}

const onboardingCommandStable = splitOnboardingCommand(hero.onboardingCommandStable);
---

<section class="hero">
  <div class="container hero-shell">
    <div class="hero-copy">
      <a
        href={tidbCloudHref}
        target="_blank"
        rel="noopener noreferrer"
        class="hero-credit"
      >
        <span data-i18n="hero.poweredByLabel">{poweredByLabel}</span>
        <img src="/tidb-logo.svg" alt="TiDB Cloud" />
      </a>

      <h1 class="title">
        <span class="title-line" data-i18n="hero.titleLead">{hero.titleLead}</span>
        <span class="title-muted">
          <span class="title-inline">
            <span data-i18n="hero.titleAccent">{hero.titleAccent}</span>
            <span class="cursor"></span>
          </span>
        </span>
      </h1>

      <p class="subtitle" data-i18n="hero.subtitle">
        {hero.subtitle}
      </p>

      <div class="cta-grid" data-onboarding-shell data-onboarding-version="stable">
        {showOnboardingVersionTabs && (
          <div class="cta-head">
            <div
              class="cta-version-tabs"
              role="tablist"
              aria-label={hero.onboardingLabel}
              data-i18n-attr="aria-label:hero.onboardingLabel"
            >
              <button
                type="button"
                class="cta-version-tab is-active"
                role="tab"
                aria-selected="true"
                data-onboarding-version-tab="stable"
                data-i18n="hero.onboardingStableLabel"
              >
                {hero.onboardingStableLabel}
              </button>
              <button
                type="button"
                class="cta-version-tab"
                role="tab"
                aria-selected="false"
                data-onboarding-version-tab="beta"
                data-i18n="hero.onboardingBetaLabel"
              >
                {hero.onboardingBetaLabel}
              </button>
            </div>
          </div>
        )}
        <div class="cta-card surface-card">
          <div class="cta-card-head">
            <p class="cta-label" data-i18n="hero.onboardingLabel">{hero.onboardingLabel}</p>
            <span class="cta-badge" data-i18n="hero.onboardingBadge">{hero.onboardingBadge}</span>
          </div>
          <div class="cta-command">
            <code
              data-onboarding-command
              data-command-stable={hero.onboardingCommandStable}
              data-command-beta={hero.onboardingCommandBeta}
            >
              {onboardingCommandStable.prefix}
              {onboardingCommandStable.url && (
                <a
                  href={onboardingCommandStable.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="onboarding-command-link"
                >
                  {onboardingCommandStable.url}
                </a>
              )}
              {onboardingCommandStable.suffix}
            </code>
            <button
              type="button"
              class="copy-button"
              data-copy-button
              data-copy-text={hero.onboardingCommandStable}
              aria-label={aria.copyOnboarding}
              title={aria.copyOnboarding}
              data-i18n-attr="aria-label:aria.copyOnboarding;title:aria.copyOnboarding"
            >
              <svg class="copy-icon copy-icon-default" viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M9 9a2 2 0 0 1 2-2h7a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-7a2 2 0 0 1-2-2z"
                  fill="none"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.7"
                />
                <path
                  d="M15 7V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h1"
                  fill="none"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.7"
                />
              </svg>
              <svg class="copy-icon copy-icon-success" viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M20 7L10 17l-5-5"
                  fill="none"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                />
              </svg>
            </button>
          </div>
          <p class="cta-hint" data-i18n="hero.onboardingHint" data-i18n-html set:html={hero.onboardingHint}></p>
          <p class="sr-only" data-copy-feedback aria-live="polite"></p>
        </div>
      </div>

      {hero.guideSelector && (
        <aside class="works-with" aria-label={hero.guideSelector.label}>
          <p class="works-with-label" data-i18n="hero.guideSelector.label">{hero.guideSelector.label}</p>
          <ul class="works-with-list">
            {hero.guideSelector.items.map((item, index) => {
              const target = agentGuideTargets[item.id];
              return (
                <>
                  {index > 0 && (
                    <li class="works-with-sep" aria-hidden="true">◆</li>
                  )}
                  <li>
                    <a
                      class="works-with-link"
                      href={target.href}
                      target={target.external ? "_blank" : undefined}
                      rel={target.external ? "noopener noreferrer" : undefined}
                    >
                      <span class="works-with-name" data-i18n={`hero.guideSelector.items.${index}.label`}>{item.label}</span>
                      {target.external && (
                        <span class="works-with-arrow" aria-hidden="true">↗</span>
                      )}
                    </a>
                  </li>
                </>
              );
            })}
          </ul>
        </aside>
      )}

      <div class="beta-feature-wrap" data-beta-highlights hidden>
        <article class="beta-feature-card surface-card">
          <div class="beta-feature-head">
            <h2 class="highlight-title beta-feature-title" data-i18n="hero.betaFeature.title">
              {hero.betaFeature.title}
            </h2>
            <span class="beta-feature-badge">New</span>
          </div>
          <p class="highlight-description beta-feature-description" data-i18n="hero.betaFeature.description">
            {hero.betaFeature.description}
          </p>
        </article>
      </div>

      <div class="hero-highlights">
        {hero.highlights.map((highlight, index) => (
          <article class="highlight-card surface-card">
            <h2 class="highlight-title" data-i18n={`hero.highlights.${index}.title`}>
              {highlight.title}
            </h2>
            <p class="highlight-description" data-i18n={`hero.highlights.${index}.description`}>
              {highlight.description}
            </p>
          </article>
        ))}
      </div>

      <aside class="hero-footer">
        <a
          href={tidbZeroHref}
          target="_blank"
          rel="noopener noreferrer"
          class="hero-substrate-link"
          data-i18n="hero.substrateCtaLabel"
        >
          {substrateCtaLabel}
        </a>
      </aside>
    </div>
  </div>
</section>

<style>
  .hero {
    display: flex;
    align-items: center;
    min-height: calc(100dvh - 70px);
    padding: clamp(2.25rem, 5vh, 5rem) 0 clamp(1.6rem, 3.4vh, 3rem);
  }

  .hero-shell {
    position: relative;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .hero-copy {
    width: min(100%, var(--content-rail));
    margin: 0 auto;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    letter-spacing: 0.22em;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .title {
    font-size: clamp(3.125rem, 4.7vw, 3.75rem);
    line-height: 1.08;
    max-width: 100%;
    text-wrap: balance;
    margin-bottom: 1rem;
  }

  .title-line {
    display: inline-block;
    white-space: nowrap;
  }

  .title-muted {
    display: block;
    color: var(--text-hero-muted);
    margin-top: 0.06em;
  }

  .title-inline {
    display: inline-flex;
    align-items: baseline;
    gap: 0.02em;
    white-space: nowrap;
  }

  .subtitle {
    font-size: clamp(1.0625rem, 1.4vw, 1.125rem);
    color: var(--text-dim);
    max-width: 576px;
    line-height: 1.79;
    margin-bottom: 1.5rem;
  }

  .hero-credit {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: 1.1rem;
    padding: 0.32rem 0.7rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--surface-elevated-end);
    color: var(--text-soft);
    font-size: 0.8rem;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    line-height: 1;
    transition: color 0.18s ease, border-color 0.18s ease;
  }

  .hero-credit:hover,
  .hero-credit:focus-visible {
    color: var(--text);
    border-color: var(--border-strong);
    opacity: 1;
  }

  .hero-credit img {
    display: block;
    width: auto;
    height: 0.85rem;
    transition: opacity 0.18s ease;
  }

  .hero-credit:hover img,
  .hero-credit:focus-visible img {
    opacity: 0.92;
  }

  .cta-grid {
    width: min(100%, var(--content-rail));
    margin-bottom: 0.55rem;
  }

  .cta-grid[data-onboarding-shell] {
    display: flex;
    flex-direction: column;
  }

  .works-with {
    width: min(100%, var(--content-rail));
    margin: 2rem 0 0;
    display: grid;
    gap: 0.7rem;
  }

  .works-with-label {
    color: var(--text-soft);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    margin: 0;
  }

  .works-with-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.85rem;
  }

  .works-with-link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.28rem;
    color: var(--text);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .works-with-name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease;
  }

  .works-with-link:hover .works-with-name,
  .works-with-link:focus-visible .works-with-name {
    border-bottom-color: var(--accent);
  }

  .works-with-arrow {
    display: inline-flex;
    align-items: baseline;
    color: var(--text-soft);
    font-size: 0.78em;
    transform: translateY(-0.05em);
    text-decoration: none;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .works-with-link:hover .works-with-arrow,
  .works-with-link:focus-visible .works-with-arrow {
    color: var(--accent);
    transform: translate(0.1em, -0.18em);
  }

  .works-with-sep {
    color: var(--accent);
    font-size: 0.5rem;
    line-height: 1;
    opacity: 0.5;
    transform: translateY(-0.2em);
  }

  .cta-grid[data-onboarding-version='beta'] {
    margin-bottom: 0.85rem;
  }

  .cta-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.85rem;
  }

  .cta-version-tabs {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.25rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--button-bg);
  }

  .cta-version-tab {
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: var(--text-dim);
    padding: 0.38rem 0.8rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .cta-version-tab:hover {
    color: var(--text);
  }

  .cta-version-tab.is-active {
    background: var(--button-active-bg);
    color: var(--text);
  }

  .cta-card {
    padding: 0.95rem 1.05rem 0.85rem;
    background: linear-gradient(180deg, var(--surface-elevated-start), var(--surface-elevated-end));
    border: 1px solid var(--border-strong);
    box-shadow: var(--surface-shadow-soft);
  }

  .hero-highlights {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    width: min(100%, var(--content-rail));
    margin-top: 2rem;
  }

  .highlight-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem 1.05rem 1.1rem;
    min-height: 0;
  }

  .beta-feature-wrap {
    width: min(100%, var(--content-rail));
    margin-bottom: 0.85rem;
  }

  .beta-feature-wrap[hidden] {
    display: none !important;
    margin: 0 !important;
  }

  .beta-feature-card {
    min-height: 0;
    padding: 1rem 1rem 1.05rem;
    opacity: 0;
    transform: translate3d(0, 18px, 0);
  }

  .beta-feature-wrap.is-visible .beta-feature-card {
    animation: beta-highlight-slide 0.46s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .beta-feature-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.9rem;
    margin-bottom: 0.65rem;
  }

  .beta-feature-title {
    margin-bottom: 0;
  }

  .beta-feature-badge {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.24rem 0.56rem;
    border: 1px solid var(--button-active-border);
    border-radius: 999px;
    background: var(--button-active-bg);
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .beta-feature-description {
    max-width: none;
  }

  .cta-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.7rem;
  }

  .cta-label {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--text);
    margin: 0;
    line-height: 1.2;
  }

  .cta-badge {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 0.22rem 0.55rem;
    border-radius: 999px;
    line-height: 1.2;
    white-space: nowrap;
  }

  .cta-hint {
    font-size: 0.8rem;
    color: var(--text-soft);
    line-height: 1.5;
    margin: 0.7rem 0 0;
  }

  .cta-hint :global(strong) {
    font-weight: 600;
    color: var(--text);
  }

  .cta-card code {
    display: block;
    flex: 1;
    font-size: 0.96rem;
    color: var(--white-soft);
    line-height: 1.55;
    word-break: break-word;
  }

  .cta-card code :global(.onboarding-command-link) {
    color: color-mix(in srgb, var(--white-soft) 78%, var(--text-soft));
    text-decoration: underline;
    text-decoration-color: transparent;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.14em;
    transition: color 0.18s ease, text-decoration-color 0.18s ease;
  }

  .cta-card code :global(.onboarding-command-link:hover),
  .cta-card code :global(.onboarding-command-link:focus-visible) {
    opacity: 1;
    color: var(--text);
    text-decoration-color: currentColor;
  }

  .cta-command {
    display: flex;
    align-items: flex-start;
    gap: 0.9rem;
  }

  .copy-button {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    min-height: 34px;
    padding: 0;
    border: 1px solid var(--border);
    border-radius: 0.7rem;
    background: var(--button-bg);
    color: var(--white-soft);
    cursor: pointer;
    transition: background-color 0.2s, border-color 0.2s, color 0.2s;
  }

  .copy-icon {
    width: 16px;
    height: 16px;
  }

  .copy-icon-success {
    display: none;
  }

  .copy-button:hover {
    background: var(--button-hover-bg);
    border-color: var(--border-strong);
  }

  .copy-button.is-copied {
    color: var(--accent);
    background: var(--button-active-bg);
    border-color: var(--button-active-border);
  }

  .copy-button.is-copied .copy-icon-default {
    display: none;
  }

  .copy-button.is-copied .copy-icon-success {
    display: block;
  }

  .highlight-title {
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--text);
  }

  @keyframes beta-highlight-slide {
    from {
      opacity: 0;
      transform: translate3d(0, 20px, 0);
    }

    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  .highlight-description {
    font-size: 0.95rem;
    line-height: 1.58;
    color: var(--text-dim);
  }

  .hero-footer {
    width: min(100%, var(--content-rail));
    margin-top: 1.5rem;
  }

  .hero-substrate-link {
    color: var(--text-soft);
    font-size: 0.85rem;
    line-height: 1.5;
    text-decoration: none;
    transition: color 0.18s ease;
  }

  .hero-substrate-link:hover,
  .hero-substrate-link:focus-visible {
    color: var(--text);
    opacity: 1;
  }

  @media (min-width: 900px) and (max-height: 980px) {
    .hero {
      min-height: calc(100dvh - 70px);
      padding-top: 1.7rem;
      padding-bottom: 1.25rem;
    }

    .eyebrow {
      margin-bottom: 0.85rem;
    }

    .title {
      font-size: clamp(3rem, 4.7vw, 3.75rem);
      line-height: 1.08;
      max-width: 100%;
      text-wrap: balance;
      margin-bottom: 0.9rem;
    }

    .subtitle {
      font-size: 1.0625rem;
      line-height: 1.79;
      max-width: 576px;
      margin-bottom: 1.35rem;
    }

    .works-with {
      margin-top: 1.7rem;
    }

    .hero-footer {
      margin-top: 1.7rem;
    }

    .cta-card {
      padding: 0.85rem 0.95rem 0.95rem;
    }

    .cta-card-head {
      margin-bottom: 0.6rem;
    }
  }

  @media (min-width: 900px) and (max-height: 860px) {
    .hero {
      padding-top: 1.2rem;
      padding-bottom: 1rem;
    }

    .title {
      font-size: clamp(3rem, 4.7vw, 3.75rem);
      line-height: 1.08;
      max-width: 100%;
      text-wrap: balance;
    }

    .subtitle {
      font-size: 1.125rem;
      line-height: 1.79;
      margin-bottom: 1.1rem;
    }

    .works-with {
      margin-top: 1.5rem;
    }

    .hero-footer {
      margin-top: 1.5rem;
    }

    .cta-card code {
      font-size: 0.92rem;
      line-height: 1.5;
    }

    .highlight-title {
      font-size: 0.92rem;
    }

    .highlight-description {
      font-size: 0.88rem;
      line-height: 1.5;
    }
  }

  @media (max-width: 720px) {
    .hero-copy {
      width: 100%;
    }

    .title {
      font-size: clamp(2.75rem, 11vw, 3.35rem);
      max-width: 100%;
      text-wrap: balance;
    }

    .title-line {
      white-space: normal;
    }

    .title-inline {
      display: inline;
      white-space: normal;
    }

    .cta-command {
      flex-direction: column;
    }

    .cta-head {
      align-items: flex-start;
      flex-direction: column;
    }

    .cta-card-head {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.45rem;
    }

    .works-with-list {
      gap: 0.45rem 0.7rem;
    }

    .works-with-name {
      font-size: 0.95rem;
    }

    .works-with-sep {
      font-size: 0.45rem;
    }

    .beta-feature-head {
      align-items: flex-start;
      flex-direction: column;
    }

    .hero-highlights {
      grid-template-columns: 1fr;
      gap: 0.85rem;
    }

    .hero-footer {
      margin-top: 1.25rem;
    }

    .hero-credit {
      margin-bottom: 0.85rem;
      padding: 0.3rem 0.65rem;
      font-size: 0.74rem;
    }

    .hero-credit img {
      height: 0.78rem;
    }
  }

  @media (max-width: 560px) {
    .hero {
      padding-top: 4.2rem;
    }

    .title {
      font-size: clamp(2.4rem, 10.8vw, 3rem);
      line-height: 1.04;
    }

    .eyebrow {
      font-size: 0.74rem;
      letter-spacing: 0.2em;
    }

    .subtitle {
      font-size: 1.04rem;
    }
  }
</style>
