---
import type { SiteBillingPageCopy } from '../content/site';

interface Props {
  billing: SiteBillingPageCopy;
}

const { billing } = Astro.props;
---

<section id="billing" class="billing-section">
  <div class="container billing-stack">
    <div class="section-head">
      <p class="section-kicker" data-i18n="billing.kicker">{billing.kicker}</p>
      <h2 class="section-title" data-i18n="billing.title">{billing.title}</h2>
      <p class="section-desc" data-i18n="billing.description">
        {billing.description}
      </p>
    </div>

    <div class="pricing-table-wrap surface-card">
      <table class="pricing-table">
        <thead>
          <tr>
            <th scope="col" class="feature-heading"></th>
            {billing.tiers.map((tier, index) => (
              <th
                scope="col"
                class:list={['tier-heading', tier.highlighted && 'is-highlighted']}
              >
                <div class="card-header">
                  <h3 class="tier-name" data-i18n={`billing.tiers.${index}.name`}>{tier.name}</h3>
                  <div class="tier-price-row">
                    <span
                      class:list={['tier-price', tier.promoPrice && 'is-crossed']}
                      data-i18n={`billing.tiers.${index}.price`}
                    >
                      {tier.price}
                    </span>
                    {tier.promoPrice && (
                      <span class="tier-price tier-price-promo" data-i18n={`billing.tiers.${index}.promoPrice`}>
                        {tier.promoPrice}
                      </span>
                    )}
                    {tier.period && (
                      <span class="tier-period" data-i18n={`billing.tiers.${index}.period`}>{tier.period}</span>
                    )}
                  </div>
                  {tier.ctaAction === 'mailto' ? (
                    <button
                      type="button"
                      class="cta-button"
                      data-billing-contact
                      data-billing-track
                      data-tier={tier.name}
                      data-i18n={`billing.tiers.${index}.ctaLabel`}
                    >
                      {tier.ctaLabel}
                    </button>
                  ) : (
                    <button
                      type="button"
                      class="cta-button"
                      data-billing-alert
                      data-billing-track
                      data-tier={tier.name}
                      data-i18n={`billing.tiers.${index}.ctaLabel`}
                    >
                      {tier.ctaLabel}
                    </button>
                  )}
                </div>
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {billing.featureLabels.map((label, featureIndex) => (
            <tr>
              <th scope="row" class="feature-label" data-i18n={`billing.featureLabels.${featureIndex}`}>
                {label}
              </th>
              {billing.tiers.map((tier, tierIndex) => (
                <td class:list={[tier.highlighted && 'is-highlighted']}>
                  <span data-i18n={`billing.tiers.${tierIndex}.features.${featureIndex}`}>
                    {tier.features[featureIndex]}
                  </span>
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <div
    class="modal-overlay"
    id="billing-modal"
    data-billing-modal
    hidden
  >
    <div class="modal-card surface-card">
      <p
        class="modal-message"
        data-billing-alert-message
        data-i18n="billing.alertMessage"
      >
        {billing.alertMessage}
      </p>
      <div class="modal-contact-panel" data-billing-contact-panel hidden>
        <p class="modal-message" data-i18n="billing.contactMessage">
          {billing.contactMessage}
        </p>
        <p class="modal-email" data-billing-contact-email>{billing.contactEmail}</p>
        <button
          type="button"
          class="modal-copy-button"
          data-billing-copy-email
          data-i18n="billing.contactCopyLabel"
        >
          {billing.contactCopyLabel}
        </button>
        <p class="modal-feedback" data-billing-copy-feedback aria-live="polite"></p>
        <span data-billing-copy-success hidden data-i18n="billing.contactCopiedMessage">
          {billing.contactCopiedMessage}
        </span>
        <span data-billing-copy-failure hidden data-i18n="billing.contactCopyFailedMessage">
          {billing.contactCopyFailedMessage}
        </span>
      </div>
      <button type="button" class="modal-close-button" data-billing-modal-close data-i18n="billing.modalOkLabel">{billing.modalOkLabel}</button>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var modal = document.querySelector('[data-billing-modal]');
    var closeBtn = document.querySelector('[data-billing-modal-close]');
    var alertMessage = document.querySelector('[data-billing-alert-message]');
    var contactPanel = document.querySelector('[data-billing-contact-panel]');
    var contactEmail = document.querySelector('[data-billing-contact-email]');
    var copyButton = document.querySelector('[data-billing-copy-email]');
    var copyFeedback = document.querySelector('[data-billing-copy-feedback]');
    var copySuccess = document.querySelector('[data-billing-copy-success]');
    var copyFailure = document.querySelector('[data-billing-copy-failure]');
    if (
      !modal ||
      !closeBtn ||
      !alertMessage ||
      !contactPanel ||
      !contactEmail ||
      !copyButton ||
      !copyFeedback ||
      !copySuccess ||
      !copyFailure
    ) {
      return;
    }

    function trackCta(tier, label) {
      if (typeof window.gtag === 'function') {
        window.gtag('event', 'billing_cta_click', {
          tier_name: tier,
          cta_label: label,
          transport_type: 'beacon',
        });
      }
    }

    function openModal(mode) {
      alertMessage.hidden = mode !== 'alert';
      contactPanel.hidden = mode !== 'contact';
      copyFeedback.textContent = '';
      modal.hidden = false;
      requestAnimationFrame(function () {
        modal.classList.add('is-visible');
      });
    }

    function closeModal() {
      modal.classList.remove('is-visible');
      setTimeout(function () {
        modal.hidden = true;
      }, 200);
    }

    async function copyContactEmail() {
      var email = contactEmail.textContent ? contactEmail.textContent.trim() : '';
      if (!email) {
        return false;
      }

      try {
        await navigator.clipboard.writeText(email);
        return true;
      } catch (error) {
        var textarea = document.createElement('textarea');
        textarea.value = email;
        textarea.setAttribute('readonly', '');
        textarea.style.position = 'absolute';
        textarea.style.left = '-9999px';
        document.body.appendChild(textarea);
        textarea.select();

        var copied = false;
        try {
          copied = document.execCommand('copy');
        } catch (copyError) {
          copied = false;
        }

        document.body.removeChild(textarea);
        return copied;
      }
    }

    document.querySelectorAll('[data-billing-alert]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        openModal('alert');
      });
    });

    document.querySelectorAll('[data-billing-contact]').forEach(function (btn) {
      btn.addEventListener('click', async function () {
        openModal('contact');
        var copied = await copyContactEmail();
        copyFeedback.textContent = copied
          ? copySuccess.textContent.trim()
          : copyFailure.textContent.trim();
      });
    });

    document.querySelectorAll('[data-billing-track]').forEach(function (el) {
      el.addEventListener('click', function () {
        trackCta(el.dataset.tier || '', el.textContent ? el.textContent.trim() : '');
      });
    });

    copyButton.addEventListener('click', async function () {
      var copied = await copyContactEmail();
      copyFeedback.textContent = copied
        ? copySuccess.textContent.trim()
        : copyFailure.textContent.trim();
    });

    closeBtn.addEventListener('click', closeModal);

    modal.addEventListener('click', function (e) {
      if (e.target === modal) closeModal();
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !modal.hidden) closeModal();
    });
  })();
</script>

<style>
  .billing-section {
    padding-top: 5rem;
    padding-bottom: 5rem;
  }

  .billing-stack {
    display: grid;
    gap: 2.5rem;
  }

  .section-head {
    width: min(100%, var(--content-rail));
    margin: 0 auto;
    text-align: center;
  }

  .section-head .section-desc {
    margin-left: auto;
    margin-right: auto;
  }

  .pricing-table-wrap {
    width: min(100%, var(--max-w));
    margin: 0 auto;
    padding: 0;
    overflow-x: auto;
  }

  .pricing-table {
    width: 100%;
    min-width: 920px;
    border-collapse: collapse;
    table-layout: fixed;
  }

  .card-header {
    display: grid;
    gap: 1rem;
    min-height: 11.5rem;
    padding: 1.5rem 1rem 1.25rem;
    align-content: start;
    text-align: left;
  }

  .feature-heading {
    width: 19%;
  }

  .tier-heading,
  .feature-label,
  .pricing-table td {
    border-bottom: 1px solid var(--border);
  }

  .tier-heading {
    vertical-align: top;
    font-weight: inherit;
  }

  .tier-heading.is-highlighted,
  .pricing-table td.is-highlighted {
    background: color-mix(in srgb, var(--accent) 14%, transparent);
  }

  .tier-heading.is-highlighted {
    box-shadow: inset 0 2px 0 var(--accent);
  }

  .tier-name {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0;
    color: var(--accent);
    margin: 0;
  }

  .tier-price-row {
    display: flex;
    align-items: baseline;
    gap: 0.15rem;
  }

  .tier-price {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1;
    color: var(--text);
  }

  .tier-price.is-crossed {
    color: var(--text-dim);
    font-size: 2rem;
    text-decoration: line-through;
    text-decoration-thickness: 0.12em;
    text-decoration-color: color-mix(in srgb, var(--text) 70%, transparent);
  }

  .tier-price-promo {
    margin-left: 0.35rem;
  }

  .tier-period {
    font-size: 0.95rem;
    color: var(--text-dim);
  }

  .feature-label,
  .pricing-table td {
    padding: 1rem;
    text-align: left;
    vertical-align: middle;
  }

  .feature-label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text);
    background: color-mix(in srgb, var(--surface) 90%, var(--text) 10%);
  }

  .pricing-table td {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text);
    line-height: 1.45;
  }

  .cta-button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 3rem;
    padding: 0.8rem 1rem;
    border-radius: 0.85rem;
    border: 1px solid color-mix(in srgb, var(--text) 18%, transparent);
    background: linear-gradient(
      135deg,
      var(--text) 0%,
      color-mix(in srgb, var(--text) 74%, var(--accent)) 100%
    );
    color: var(--bg-deep);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, white 22%, transparent),
      0 10px 24px color-mix(in srgb, var(--text) 12%, transparent);
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0;
    text-decoration: none;
    cursor: pointer;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      opacity 0.2s ease,
      border-color 0.2s ease;
  }

  .cta-button:hover {
    transform: translateY(-1px) scale(1.01);
    opacity: 0.97;
    border-color: color-mix(in srgb, var(--text) 26%, transparent);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, white 24%, transparent),
      0 14px 32px color-mix(in srgb, var(--text) 16%, transparent);
  }

  .modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(6px);
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .modal-overlay[hidden] {
    display: none;
  }

  .modal-overlay.is-visible {
    opacity: 1;
  }

  .modal-card {
    max-width: 480px;
    width: calc(100% - 2rem);
    padding: 2rem;
    text-align: center;
    transform: translateY(12px) scale(0.97);
    transition: transform 0.2s ease;
  }

  .modal-overlay.is-visible .modal-card {
    transform: translateY(0) scale(1);
  }

  .modal-message {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text);
    margin-bottom: 1.5rem;
  }

  .modal-contact-panel {
    display: grid;
    gap: 0.85rem;
    margin-bottom: 1.5rem;
  }

  .modal-contact-panel .modal-message {
    margin-bottom: 0;
  }

  .modal-email {
    margin: 0;
    padding: 0.85rem 1rem;
    border-radius: 0.85rem;
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--surface) 92%, black 8%);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.95rem;
    line-height: 1.5;
    user-select: all;
    word-break: break-all;
  }

  .modal-copy-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    padding: 0.65rem 1.2rem;
    border-radius: 0.75rem;
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--surface) 88%, white 12%);
    color: var(--text);
    font-family: var(--font-display);
    font-size: 0.92rem;
    font-weight: 700;
    cursor: pointer;
    transition:
      transform 0.15s ease,
      border-color 0.15s ease,
      background 0.15s ease;
  }

  .modal-copy-button:hover {
    transform: translateY(-1px);
    border-color: var(--border-strong);
    background: color-mix(in srgb, var(--surface) 82%, white 18%);
  }

  .modal-feedback {
    min-height: 1.25rem;
    margin: 0;
    color: var(--text-dim);
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .modal-close-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 7rem;
    min-height: 2.75rem;
    padding: 0.6rem 1.5rem;
    border-radius: 0.75rem;
    border: 1px solid color-mix(in srgb, var(--text) 18%, transparent);
    background: linear-gradient(
      135deg,
      var(--text) 0%,
      color-mix(in srgb, var(--text) 74%, var(--accent)) 100%
    );
    color: var(--bg-deep);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, white 22%, transparent),
      0 8px 20px color-mix(in srgb, var(--text) 12%, transparent);
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    transition:
      transform 0.15s ease,
      box-shadow 0.15s ease,
      opacity 0.15s ease;
  }

  .modal-close-button:hover {
    transform: translateY(-1px);
    opacity: 0.95;
  }

  @media (max-width: 960px) {
    .pricing-table-wrap {
      width: calc(100% + 1rem);
      margin-left: -0.5rem;
      border-radius: 0.8rem;
    }
  }

  @media (max-width: 640px) {
    .billing-section {
      padding-top: 4rem;
      padding-bottom: 4rem;
    }

    .pricing-table {
      min-width: 780px;
    }

    .tier-price {
      font-size: 2rem;
    }

    .card-header {
      min-height: 10.75rem;
      padding: 1.25rem 0.85rem 1rem;
    }

    .feature-label,
    .pricing-table td {
      padding: 0.85rem;
    }
  }
</style>
